<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="trabajoFinal.ui.controller.OperatorController"
            prefWidth="800" prefHeight="600"
            stylesheets="@styles.css"
            styleClass="root">


    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <Button text="Cerrar sesión" onAction="#cerrarSesion" styleClass="btn-secundario"/>
            <Label text="ParkUQ — Panel del Operador" styleClass="titulo-panel"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <!-- PESTAÑA: INGRESO -->
            <Tab text="Registrar Ingreso">
                <VBox spacing="10" styleClass="panel-oscuro">
                    <Label text="Datos del vehículo" styleClass="titulo-seccion"/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Placa:" prefWidth="130"/>
                        <TextField fx:id="campoPlacaIngreso" promptText="Ej: ABC123" prefWidth="200"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Tipo de vehículo:" prefWidth="130"/>
                        <ComboBox fx:id="combotipoVehiculo" prefWidth="200"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Nombre conductor:" prefWidth="130"/>
                        <TextField fx:id="campoNombreConductor" promptText="Nombre completo" prefWidth="200"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Identificación:" prefWidth="130"/>
                        <TextField fx:id="campoIdConductor" promptText="Cédula o ID" prefWidth="200"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Cilindraje (moto):" prefWidth="130"/>
                        <TextField fx:id="campoCilindraje" promptText="Solo para motos" prefWidth="200"/>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Tipo de usuario:" prefWidth="130"/>
                        <ComboBox fx:id="comboTipoUsuario" prefWidth="200"/>
                    </HBox>
                    <Button text="Registrar Ingreso" onAction="#registrarIngreso"
                            styleClass="btn-exito" prefWidth="200"/>

                    <Label fx:id="etiquetaResultadoIngreso" styleClass="mensaje-info" text=""/>
                </VBox>
            </Tab>

            <!-- PESTAÑA: SALIDA -->
            <Tab text="Registrar Salida">
                <VBox spacing="10" styleClass="panel-oscuro">
                    <Label text="Salida de vehículo" styleClass="titulo-seccion"/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Placa:" prefWidth="130"/>
                        <TextField fx:id="campoPlacaSalida" promptText="Placa del vehículo" prefWidth="200"/>
                        <Button text="Calcular y Registrar" onAction="#registrarSalida"
                                styleClass="btn-peligro"/>
                    </HBox>

                    <Label text="Recibo:" styleClass="titulo-seccion"/>
                    <TextArea fx:id="areaRecibo" prefHeight="300" editable="false" styleClass="text-area"/>
                </VBox>
            </Tab>

            <!-- PESTAÑA: CONSULTAS -->
            <Tab text="Consultas">
                <VBox spacing="10" styleClass="panel-oscuro">
                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <Label text="Vehículos en el parqueadero" styleClass="titulo-seccion"/>
                        <Button text="Actualizar" onAction="#actualizarConsultas" styleClass="button"/>
                    </HBox>

                    <TableView fx:id="tablaVehiculos" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="colPlaca" text="Placa" prefWidth="100"/>
                            <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
                            <TableColumn fx:id="colConductor" text="Conductor" prefWidth="180"/>
                            <TableColumn fx:id="colEspacio" text="Espacio" prefWidth="80"/>
                            <TableColumn fx:id="colHoraIngreso" text="Hora Ingreso" prefWidth="150"/>
                        </columns>
                    </TableView>

                    <Label fx:id="etiquetaEspaciosDisponibles"
                           styleClass="mensaje-info" text=""/>
                </VBox>
            </Tab>

            <!-- PESTAÑA: REPORTES -->
            <Tab text="Reportes del Día">
                <VBox spacing="10" styleClass="panel-oscuro">
                    <HBox spacing="10">
                        <Button text="Generar Reporte del Día" onAction="#generarReporte"
                                styleClass="button"/>
                    </HBox>
                    <TextArea fx:id="areaReporte" prefHeight="400" editable="false" styleClass="text-area"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
